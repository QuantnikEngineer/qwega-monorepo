# Application Settings
APP_NAME=Wega Common Integration Service
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8084

# Logging
LOG_LEVEL=INFO

# API Keys (at least one required)
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Redis Configuration (optional, for production)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# LLM Configuration
LLM_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# SSL Configuration
SSL_VERIFY=false

# RAG Agent URL
RAG_AGENT_URL=https://dev-wega-rag-204952354085.us-central1.run.app

# Timeout Configuration (in seconds)
AGENT_CALL_TIMEOUT=600
REQUEST_TIMEOUT=600

# SSE Streaming Configuration (heartbeat to keep connection alive during long RAG operations)
SSE_HEARTBEAT_INTERVAL=10

# Memory Configuration
CONVERSATION_MEMORY_LIMIT=20
SESSION_TTL_HOURS=24

# Sibling Orchestrator (for cross-referencing)
PLANNING_ORCHESTRATOR_URL=https://dev-wega-planning-orchestrator-204952354085.us-central1.run.app
