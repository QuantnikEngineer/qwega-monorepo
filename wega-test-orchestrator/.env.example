# ===========================================
# Wega Test Orchestrator - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=Wega Test Orchestrator
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Logging
LOG_LEVEL=INFO

# ===========================================
# API Keys (Required)
# ===========================================
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# ===========================================
# Redis Configuration (Memory Store)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# LLM Configuration
# ===========================================
LLM_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# SSL Configuration
SSL_VERIFY=true

# ===========================================
# Test Agent Endpoints
# ===========================================
#TEST_SCENARIO_AGENT_URL=https://wega-userstory-to-testcases-agent-204952354085.us-central1.run.app
TEST_SCENARIO_AGENT_URL=https://wega-testcases-agent-204952354085.us-central1.run.app
TEST_SCRIPT_AGENT_URL=https://testcase-to-scripts-agent-204952354085.us-central1.run.app

# ===========================================
# Jira Configuration
# ===========================================
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USER_EMAIL=your-email@example.com

# ===========================================
# Memory Configuration
# ===========================================
CONVERSATION_MEMORY_LIMIT=20
SESSION_TTL_HOURS=24

# ===========================================
# Sibling Orchestrator (Planning)
# ===========================================
PLANNING_ORCHESTRATOR_URL=http://localhost:8000
