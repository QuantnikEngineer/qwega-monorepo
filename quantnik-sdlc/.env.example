# =============================================================================
# QUANTNIK Frontend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values for local development.
# NEVER commit .env — it is gitignored.
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  VITE_*  → Embedded in the JS bundle at BUILD time (npm run build). │
# │            In Docker builds, set via --build-arg or Dockerfile ARG. │
# │  Non-VITE → Used by vite.config.ts dev proxy (Node.js only).        │
# │  GATEWAY_UPSTREAM → Nginx runtime var, injected via envsubst.       │
# └──────────────────────────────────────────────────────────────────────┘
# =============================================================================

# ---------------------------------------------------------------------------
# BUILD-TIME: Vite client-side variables (baked into JS bundle)
# ---------------------------------------------------------------------------

# Atlassian (used for browse links in the UI, not for API calls)
VITE_ATLASSIAN_BASE_URL=https://wegabuildiq.atlassian.net
VITE_CONFLUENCE_SPACE_ID=
VITE_JIRA_PROJECT_KEY=WEGAAIDEMO

# Gateway URL — leave EMPTY for production (nginx handles proxying).
# Only set for local dev where the Vite dev server proxies to a local gateway.
VITE_GATEWAY_URL=http://localhost:8080

# Auth toggle — set to "true" to enable the login/RBAC flow.
# The Dockerfile defaults this to "true" so production builds have auth ON.
VITE_AUTH_ENABLED=true

# Code Assistant (Droid) URL — defaults to dev Cloud Run if unset.
# VITE_CODE_ASSISTANT_URL=https://dev-quantnik-code-assistant-agent-204952354085.us-central1.run.app

# ---------------------------------------------------------------------------
# RUNTIME: Nginx container variables (injected via envsubst at startup)
# ---------------------------------------------------------------------------
# Set these as Cloud Run env vars (--set-env-vars) or in Harness pipeline.

# GATEWAY_UPSTREAM — the API Gateway Cloud Run URL that nginx proxies to.
# Example: https://quantnik-api-gateway-204952354085.us-central1.run.app
# GATEWAY_UPSTREAM=
