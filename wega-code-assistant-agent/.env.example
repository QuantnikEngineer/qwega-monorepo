# optional server settings (loaded via dotenv)
# copy to `.env` and tweak as needed

# server bind
# PORT=4000
# HOST=localhost

# droid exec tuning
# DROID_MODEL_ID=gpt-5-codex
# DROID_REASONING=low  # off|low|medium|high

# Default git repo URL (can be overridden per-session via POST /api/config)
REPO_LOCK_REMOTE_URL=https://git.harness.io/2KolbecvR0aAcgQ5uXBObA/WiproPOC/Harness_POC/Git_practice_sg.git

# Git authentication (can be overridden per-session via POST /api/config)
# REPO_LOCK_GIT_USERNAME=git
# REPO_LOCK_GIT_TOKEN=your-pat-token-here

# Repo workspace root directory (where cloned repos are stored)
# REPO_LOCK_ROOT_DIR=/app

# Commit author defaults (can be overridden per-session via POST /api/config)
# REPO_LOCK_GIT_COMMIT_AUTHOR_NAME=WEGA Repo Sync Bot
# REPO_LOCK_GIT_COMMIT_AUTHOR_EMAIL=wega-repo-sync-bot@local

# --- Jira/Atlassian Settings ---
JIRA_URL=https://wegabuildiq.atlassian.net
# JIRA_EMAIL is managed via Secret Manager
# JIRA_API_TOKEN is managed via Secret Manager