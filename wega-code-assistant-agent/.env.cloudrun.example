# ---------------------------------------------------------------
# Cloud Run environment variables
# Copy to .env.cloudrun and fill in real values before deploying.
# NEVER commit .env.cloudrun — it contains secrets.
# ---------------------------------------------------------------
#
# IMPORTANT: For Cloud Run deployment, FACTORY_API_KEY must be set!
# Get your API key from: https://app.factory.ai/settings/api-keys
#
# Deployment options:
# 1. Use deploy-cloudrun.sh script (recommended)
# 2. Set env vars directly in Cloud Run console
# 3. Use gcloud run deploy --set-env-vars
#
# ---------------------------------------------------------------

# --- GCP Settings ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=dev-wega-code-assistant-agent
CLOUD_RUN_IMAGE=us-central1-docker.pkg.dev/your-project/your-repo/wega-code-assistant-agent:latest

# --- App Settings ---
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
DROID_MODEL_ID=glm-5
DROID_REASONING=low
DROID_AUTONOMY=high

# --- Repo Lock ---
REPO_LOCK_REMOTE_URL=https://git.harness.io/2KolbecvR0aAcgQ5uXBObA/WEGA/WEGA/WEGA.git
REPO_LOCK_ROOT_DIR=/app
REPO_LOCK_GIT_USERNAME=git
REPO_LOCK_GIT_TOKEN=your-pat-token-here

# --- REQUIRED: Factory API Key ---
# Generate from: https://app.factory.ai/settings/api-keys
# This is REQUIRED for droid exec to work in Cloud Run!
FACTORY_API_KEY=fk-your-factory-api-key-here

# --- Optional ---
# REPO_LOCK_GIT_COMMIT_AUTHOR_NAME=WEGA Repo Sync Bot
# REPO_LOCK_GIT_COMMIT_AUTHOR_EMAIL=wega-repo-sync-bot@local
# CORS_ALLOWED_ORIGINS=*

# --- Jira/Atlassian Settings ---
JIRA_URL=https://wegabuildiq.atlassian.net
# JIRA_EMAIL is managed via Secret Manager
# JIRA_API_TOKEN is managed via Secret Manager

# --- Azure DevOps Settings ---
ADO_ORGANIZATION_URL=https://dev.azure.com/WiproPracticeWork
ADO_ORG=WiproPracticeWork
# ADO_PAT is managed via Secret Manager
