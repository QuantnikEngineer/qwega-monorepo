# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["*"]

# ── PostgreSQL — critical DB ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sdlc_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── PostgreSQL — non-critical DB ──────────────────────────────────────────────
POSTGRES_HOST_NC=localhost
POSTGRES_PORT_NC=5432
POSTGRES_DB_NON_CRITICAL=sdlc_kb_non_critical
POSTGRES_SSLMODE=disable

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sdlc_kb
QDRANT_COLLECTION_NON_CRITICAL=sdlc_kb_non_critical
QDRANT_VECTOR_SIZE=768
QDRANT_VERIFY_SSL=false

# ── Vertex AI ─────────────────────────────────────────────────────────────────
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_LLM_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# ── Classification ────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Repository Tokens ─────────────────────────────────────────────────────────
GITHUB_TOKEN=
HARNESS_TOKEN=

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_EMAIL=
CONFLUENCE_TOKEN=

# ── SharePoint / Microsoft Graph API ──────────────────────────────────────────
SHAREPOINT_TOKEN=
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
