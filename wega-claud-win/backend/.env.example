# WEGA Claude backend — environment variables.
#
# On Windows, copy this to backend\.env and adjust paths (Windows-friendly
# defaults shown). On Linux/macOS, the ./data/* defaults work as-is.

# Backend HTTP port. IIS reverse-proxies /api and /ws to this port.
PORT=6060

# Where new project working directories are created. Persist this path
# (NTFS folder on the Windows host, or a mounted disk).
#   Windows example:  PROJECTS_ROOT=C:\wega-data\projects
#   Linux example:    PROJECTS_ROOT=./data/projects
PROJECTS_ROOT=./data/projects

# Path to the SQLite database file. Same persistence considerations apply.
#   Windows example:  DB_PATH=C:\wega-data\wega2.db
#   Linux example:    DB_PATH=./data/wega2.db
DB_PATH=./data/wega2.db

# Claude authentication — pick ONE:
#   ANTHROPIC_API_KEY      — standard API key from console.anthropic.com.
#   CLAUDE_CODE_OAUTH_TOKEN — long-lived OAuth token from `claude setup-token`
#                             (uses your Claude subscription, no API key needed).
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# MCP Server Tokens (optional). When set, NEW projects are auto-wired with
# these MCP servers in their .claude/settings.json. Existing projects are
# not retroactively modified.

# Figma: Settings > Personal access tokens
MCP_FIGMA_TOKEN=
# Linear: Settings > API > Personal API keys
MCP_LINEAR_TOKEN=
# Notion: https://www.notion.so/my-integrations
MCP_NOTION_TOKEN=
# GitHub: Settings > Developer settings > Personal access tokens
MCP_GITHUB_TOKEN=
# Atlassian / Jira / Confluence: https://id.atlassian.com/manage-profile/security/api-tokens
MCP_ATLASSIAN_EMAIL=
MCP_ATLASSIAN_TOKEN=
MCP_ATLASSIAN_URL=
# Slack: Slack App token with the scopes you need
MCP_SLACK_TOKEN=
