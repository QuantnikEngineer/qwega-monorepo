# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Generated files
final_brd.pdf
*.log

# Distribution
dist/
build/
*.egg-info/

# Documentation files (not needed for deployment)
*.md
!README.md

# Other deployment files
.dockerignore
docker-compose.yaml
startup-script.sh
Quantnik-userstory-validator.service
deploy.sh

# NOTE: .env is NOT excluded - it will be included in the deployment
