# Core app settings
APP_NAME="WEGA Code Review Agent"
ENVIRONMENT=development
LOG_LEVEL=INFO

# Server port (Cloud Run injects $PORT automatically; locally default to 8001
# so CARA does not collide with the Planning Orchestrator on 8000).
PORT=8001

# Required integrations
# --- GitHub authentication (pick ONE path) ---
# Preferred: GitHub App auth (auto-refreshes installation tokens; no cron needed)
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=12345678
# GITHUB_PRIVATE_KEY interpretation depends on ENVIRONMENT:
#   - ENVIRONMENT=production -> the value is the inline PEM contents
#   - ENVIRONMENT!=production -> the value is a filesystem path to a PEM file
# Local dev (file path):
GITHUB_PRIVATE_KEY=~/Downloads/your-app-private-key.pem
# Production (inline PEM, multi-line, quoted):
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Fallback: static personal or installation token (installation tokens expire in ~1h)
# GITHUB_TOKEN=your-github-token

GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GOOGLE_API_KEY=your-google-api-key

# --- Optional Harness Code Repository integration ---
# Set HARNESS_PAT + HARNESS_ACCOUNT_ID to enable reviews / scans against
# Harness-hosted repos. Leave unset for GitHub-only deployments.
# HARNESS_PAT=pat.account.token
# HARNESS_ACCOUNT_ID=your-harness-account-id
# HARNESS_BASE_URL=https://app.harness.io
# HARNESS_WEBHOOK_SECRET=your-harness-webhook-secret

# Optional Jira integration
JIRA_SERVER_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-jira-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Multi-model routing (Gemini 3.1)
LLM_MODEL_FAST=gemini-fast-latest
LLM_MODEL_REASONING=gemini-pro-latest

# Backward-compatible legacy aliases are also supported:
# GENAI_PROMPT_PARSER_MODEL=gemini-fast-latest
# GENAI_REVIEW_MODEL=gemini-pro-latest

# Optional runtime overrides
REPORTS_BASE_PATH=/tmp/reports
MAX_CONTEXT_FILES=150
MAX_CONTEXT_FILE_BYTES=131072
MAX_DIFF_CHARACTERS=80000
REPOSITORY_ARCHIVE_TIMEOUT_SECONDS=60
# Parallel workers used when uploading context files to the Gemini Files API.
# Default 16. Lower if you hit 429 rate limits; set to 1 for sequential uploads.
UPLOAD_CONCURRENCY=16
