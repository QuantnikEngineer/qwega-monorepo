# =============================================================================
# QUANTNIK API Gateway — Environment Configuration
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit .env — it is gitignored.
#
# All variables are read at RUNTIME via pydantic-settings.
# In Cloud Run, set via --set-env-vars or Harness pipeline env vars.
# Defaults in app/config.py are safe for local dev; override for production.
# =============================================================================

# === Application ===
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8080

# === Upstream Services ===
# Local dev: point to locally-running services.
# Production: deploy.sh auto-computes Cloud Run URLs from profile + project number.
AUTH_SERVICE_URL=http://localhost:8090
ORCHESTRATOR_URL=http://localhost:8081
PLANNING_ORCHESTRATOR_URL=http://localhost:8082

# === CORS ===
# Use "*" for dev. Tighten to frontend URL in prod.
CORS_ORIGINS=*

# === JWT (must match auth service issuer/audience) ===
JWT_ISSUER=quantnik-auth
JWT_AUDIENCE=quantnik-api
JWKS_CACHE_TTL_SECONDS=300

# === SSE ===
SSE_HEARTBEAT_SECONDS=15
SSE_RECONNECT_MS=3000

# === Internal API Key ===
# Shared secret for gateway ↔ auth-service internal calls.
# Must match INTERNAL_API_KEY in quantnik-auth-service.
# INTERNAL_API_KEY=quantnik-internal-dev-key

# === Rate Limiting ===
# Login attempts per IP before rate-limiting kicks in
LOGIN_RATE_LIMIT_MAX=15
LOGIN_RATE_LIMIT_WINDOW=60

# === Upstream Services (additional) ===
# Test-case agent — auto-computed in Cloud Run from GCP params.
# Set explicitly for local dev if running against cloud services.
# TESTCASE_AGENT_URL=http://localhost:8083
# TESTCASE_POLL_URL=http://localhost:8083
# RAG_SERVICE_URL=http://localhost:8085
# INTEGRATION_SERVICE_URL=http://localhost:8084

# === GCP Auto-Compute ===
# When APP_ENV != development and these are set, upstream URLs are auto-computed.
# GCP_PROJECT_NUMBER=204952354085
# GCP_PROFILE_PREFIX=qa-
