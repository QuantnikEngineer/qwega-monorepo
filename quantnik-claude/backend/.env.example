PORT=6060
PROJECTS_ROOT=./data/projects
DB_PATH=./data/quantnik.db
# Optional: if set, the SDK uses this key. Otherwise it falls back to the local
# `claude` CLI's stored OAuth session (~/.claude/.credentials.json).
ANTHROPIC_API_KEY=

# MCP Server Tokens (optional - set these to auto-configure MCP servers for new projects)
# Figma: Get token from Figma > Settings > Personal access tokens
MCP_FIGMA_TOKEN=
# Linear: Get token from Linear > Settings > API > Personal API keys
MCP_LINEAR_TOKEN=
# Notion: Get token from https://www.notion.so/my-integrations
MCP_NOTION_TOKEN=
# GitHub: Get token from GitHub > Settings > Developer settings > Personal access tokens
MCP_GITHUB_TOKEN=
# Atlassian/Jira: Get API token from https://id.atlassian.com/manage-profile/security/api-tokens
MCP_ATLASSIAN_EMAIL=
MCP_ATLASSIAN_TOKEN=
MCP_ATLASSIAN_URL=
# Slack: Get token from Slack App with appropriate scopes
MCP_SLACK_TOKEN=
