# =============================================================================
# quantnik-userstory-to-testcases-agent .env template for AZURE deployment
# Copy this file to .env at the project root, then fill in real values.
# Usage:   cp envs/azure.env.example .env
# Never commit .env with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
LLM_PROVIDER=azure

# -----------------------------------------------------------------------------
# Azure OpenAI (active when LLM_PROVIDER=azure)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# -----------------------------------------------------------------------------
# Document store / Issue tracker - Azure deployments typically use:
# - SharePoint (instead of Confluence)
# - Azure DevOps (instead of Jira)
# -----------------------------------------------------------------------------
DOC_STORE_BACKEND=sharepoint
ISSUE_TRACKER_BACKEND=ado

# SharePoint
SHAREPOINT_CLIENT_ID=your-app-registration-client-id
SHAREPOINT_CLIENT_SECRET=your-app-registration-client-secret
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/your-site
SHAREPOINT_FOLDER_PATH=/path/to/folder

# Azure DevOps
ADO_ORG_URL=https://dev.azure.com/your-organization
ADO_PROJECT=your-project-name
ADO_PAT=your-personal-access-token

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PORT=8080
APP_ENV=development