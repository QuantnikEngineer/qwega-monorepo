# ── LLM Provider: "google" | "azure" ─────────────────────────────────────────
LLM_PROVIDER=google

# jira or qtest or azure_devops
TEST_CASE_PROVIDER = jira

# ── Azure OpenAI (required when LLM_PROVIDER=azure) ──────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ── Google / Vertex AI (required when LLM_PROVIDER=google) ───────────────────
PROJECT_ID=your-gcp-project-id
LOCATION=global
STAGING_BUCKET=gs://your-staging-bucket
MODEL_NAME=gemini-3-flash-preview

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net/
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=YOUR_PROJECT

# ── Xray (test management) ───────────────────────────────────────────────────
TEST_PLAN_KEY=PROJ-123
XRAY_GRAPHQL_URL=https://xray.cloud.getxray.app/api/v2/graphql
XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret

# ── qTest ─────────────────────────────────────────────────────────────────────
QTEST_BASE_URL=https://your-org.qtestnet.com/api/v3
QTEST_PROJECT_ID=123456
QTEST_TOKEN=your-qtest-token

# ── Azure DevOps ──────────────────────────────────────────────────────────────
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_PAT=your-personal-access-token

# ── SSL ───────────────────────────────────────────────────────────────────────
DISABLE_SSL_VERIFY=false

# ── Langfuse configuration ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://your-langfuse-host.example.com
LANGFUSE_TIMEOUT_SEC=20
# Path to a single PEM file with the corporate / self-signed CA chain
# used by Langfuse. Merged into the runtime CA bundle by build_cert_bundle.py.
LANGFUSE_CA_CERT_PATH=cert/Cert.txt
# Optional: raw or base64-encoded PEM injected from Secret Manager.
# When set, it is merged with the repo cert at runtime.
LANGFUSE_CA_CERT=
LANGFUSE_INSECURE_SKIP_VERIFY=false

# ── Workflow envelope (cross-agent tracing) ───────────────────────────────────
# Default values picked up by utils/envelope.py for every observation.
TENANT=default
APP_ENV=development
AGENT_NAME=quantnik-userstory-to-testcases-agent
AGENT_VERSION=dev
PROMPT_VERSION=dev

# ── OTEL Collector (optional - for Prometheus/Grafana) ───────────────────────
OTEL_CA_CERT_PATH=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=quantnik-userstory-to-testcases-agent
OTEL_RESOURCE_ATTRIBUTES=service.namespace=quantnik,deployment.environment=dev
OTEL_COLLECTOR_ENDPOINT=
OTEL_COLLECTOR_AUTH_TOKEN=
OTEL_COLLECTOR_HEADERS=
OTEL_COLLECTOR_TIMEOUT_SEC=20
