# Build-Software Orchestrator — environment variables

PORT=8083
APP_ENV=development
LOG_LEVEL=INFO

# LLM — set at least one
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Child orchestrator URLs (auto-built from GCP profile if not set)
PLANNING_ORCHESTRATOR_URL=http://localhost:8000
TEST_ORCHESTRATOR_URL=http://localhost:8001

# GCP (for auto URL construction in Cloud Run)
GCP_PROJECT_NUMBER=204952354085
GCP_REGION=us-central1
APP_PROFILE=dev

# GitHub — create a Personal Access Token with repo + write:org scope
GITHUB_TOKEN=
GITHUB_ORG=QuantnikEngineer

# Vercel — optional, enables auto-deployment of the generated frontend
VERCEL_TOKEN=

# SSL
SSL_VERIFY=true
