# Environment secrets - NEVER commit
.env
.env.local
.env.*.local

# Certificates
# The corporate Langfuse ALB cert (cert/Cert.txt) IS tracked so the agent
# can talk to internal Langfuse over self-signed TLS without depending on
# Secrets Manager being wired into every deployment target. Other cert
# files (e.g. runtime-built combined_ca.pem) remain ignored.
cert/*
!cert/Cert.txt

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

