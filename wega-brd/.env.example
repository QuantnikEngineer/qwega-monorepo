# ── Required: Google Gemini ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Optional: LLM model override ───────────────────────────────────────────
# GEMINI_MODEL=gemini-3-flash-preview

# ── Optional: Confluence integration (required for publish + brownfield) ───
# Paste the full URL of the parent Confluence page where BRDs will be published.
# CONFLUENCE_PARENT_PAGE_URL=https://your-domain.atlassian.net/wiki/spaces/SPACEKEY/pages/123456/Parent+Page+Title
# CONFLUENCE_EMAIL=your-email@company.com
# CONFLUENCE_API_TOKEN=your-atlassian-api-token

# ── Optional: Output directory ─────────────────────────────────────────────
# BRD_OUTPUT_DIR=./output

# ── Optional: Logging ──────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=text
