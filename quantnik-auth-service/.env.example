# =============================================================================
# QUANTNIK Auth Service — Environment Configuration
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit .env — it is gitignored.
#
# All variables are read at RUNTIME via pydantic-settings.
# In Cloud Run, set via --set-env-vars / --update-secrets or Harness pipeline.
# =============================================================================

# === Application ===
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8090

# === Database ===
# Local development: use local PostgreSQL.
# Cloud Run: uses AWS RDS (set via gcloud --set-env-vars, NOT from this file).
# The auth-service ALWAYS uses PostgreSQL (never SQLite).
#
# Local:
DATABASE_URL=postgresql+asyncpg://postgres:PG$0up@localhost:5432/wega_auth
# Cloud Run (RDS — set as env var on the service, not here):
# DATABASE_URL=postgresql+asyncpg://postgres:<URL-ENCODED-PASSWORD>@quantnik-dev-rag.cza0q2wish6n.ap-south-1.rds.amazonaws.com:5432/wega_auth?ssl=require
# NOTE: Password with special chars ($, :, <, >, |, #) must be URL-encoded.
#   python -c "from urllib.parse import quote; print(quote('YOUR_PASSWORD', safe=''))"
DATABASE_ECHO=false

# === JWT Configuration ===
# RS256 key pair — generate with:  python scripts/generate_keys.py
# Production: mount from GCP Secret Manager (deploy.sh --use-secrets).
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=quantnik-auth
JWT_AUDIENCE=quantnik-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === Argon2 Password Hashing (OWASP 2025 defaults) ===
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1
ARGON2_HASH_LEN=32
ARGON2_SALT_LEN=16

# === Cookie ===
# COOKIE_SECURE=false for local dev (HTTP). Set true in prod (HTTPS).
COOKIE_SECURE=false
# SameSite: "strict" for prod, "lax" for cross-origin dev/demo setups.
COOKIE_SAMESITE=lax
COOKIE_PATH=/auth

# === CORS ===
# Use "*" for dev. In prod, deploy.sh sets this to the frontend Cloud Run URL.
CORS_ORIGINS=*

# === Security / Rate Limiting ===
TRUSTED_PROXY_IPS=127.0.0.1
# Account lockout (tighten for production)
LOCKOUT_THRESHOLD=15
LOCKOUT_WINDOW_MINUTES=5
LOCKOUT_BACKOFF_BASE_SECONDS=1
LOCKOUT_BACKOFF_MAX_SECONDS=10
# Registration rate limit
REGISTRATION_RATE_LIMIT_MAX=30
REGISTRATION_RATE_LIMIT_WINDOW=3600

# === Internal API Key ===
# Shared secret for gateway ↔ auth-service internal calls.
# Must match INTERNAL_API_KEY in quantnik-api-gateway.
# Required for gateway→auth-service trust on Cloud Run.
# Default is fine for local dev. On Cloud Run, set a 48-byte cryptographic key
# via: gcloud run services update --update-env-vars INTERNAL_API_KEY=<key>
INTERNAL_API_KEY=quantnik-internal-dev-key

# === Encryption (Fernet key for project secrets) ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WEGA_SECRET_KEY=

# === Frontend ===
# Used for activation email links. In prod, set to frontend Cloud Run URL.
FRONTEND_URL=http://localhost:3000

# === Registration Defaults ===
# Optional: set a default project for self-registration.
# When configured, the /register page auto-selects project-mode registration.
# Leave blank or unset for standard PM-mode registration.
REGISTRATION_DEFAULT_PROJECT_SLUG=
# Role assigned to users who self-register via project mode (default: po_sm_ba).
REGISTRATION_DEFAULT_ROLE=po_sm_ba
