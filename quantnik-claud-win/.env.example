# quantnik-claud-win — server environment variables
# Copy this to .env and fill in the values before running docker compose up.
# Docker Compose reads this file automatically from the same directory.

# ── Anthropic (required for Claude agent to work) ──────────────────────────
ANTHROPIC_API_KEY=

# ── Atlassian / Jira / Confluence MCP ──────────────────────────────────────
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
MCP_ATLASSIAN_EMAIL=
MCP_ATLASSIAN_TOKEN=
MCP_ATLASSIAN_URL=https://your-domain.atlassian.net

# ── GitHub (required for /build-software test scripts + code push) ──────────
# Create a PAT with repo + write:org scopes
GITHUB_TOKEN=
